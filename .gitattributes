# Pin line endings for files where consumers compute hashes against the
# committed bytes. Phase 3 inventory contracts (`expected.yaml`) are hashed
# at build time (R6 in-image hash assertion) and at Phase 6 forensic-readback
# time. CRLF/LF drift across platforms would break the hash agreement.
#
# See:
# - docs/superpowers/plans/phase-3-overlays.md Task 7.D (Pass-2 Charge 7)
# - runtime/scripts/overlay-smoke.sh (R6 hash check)
runtime/overlays/*/expected.yaml text eol=lf

# Phase 4 router: shell scripts and the JSON corpus must stay LF.
# parse.sh is sourced by run-cases.sh on Linux runners; CRLF would break
# `read -ra` and `[[:space:]]` matching. cases.json contains literal `\r`
# in one adversarial case body — preserving LF endings on the file itself
# keeps the test harness deterministic across platforms.
claude-command-router/lib/*.sh text eol=lf
claude-command-router/lib/filler_words.txt text eol=lf
claude-command-router/tests/*.sh text eol=lf
claude-command-router/tests/cases.json text eol=lf
